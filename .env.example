# Copy this file to .env and fill in the value. .env is gitignored.
#
# Server-side only. This key is read inside the server function in
# src/lib/demo-request.ts and never reaches the browser.
#
# Local: put the key in .env, then `bun run preview` (the preview script
#        stages .env into the Worker build as .dev.vars).
# Production: do NOT ship .env. Run:
#        npx wrangler secret put RESEND_API_KEY --name compliance-disco
#
# Mint a key at https://resend.com/api-keys
RESEND_API_KEY=

{
  "manifest_version": "1.0.0",
  "purpose": "Machine-readable index of the Marketing Compliance Agent test corpus. This is the file the Hermes agent reads to discover what it can assess.",
  "assessment_date": "2026-07-12",
  "company_snapshot": "company-current-compliance-status.json",
  "specification": "marketing-compliance-agent.md",
  "agent_readable": [
    "index.json",
    "company-current-compliance-status.json",
    "scenarios/*.input.json"
  ],
  "agent_must_not_read": [
    "oracles/*.oracle.json — these hold the expected outcomes. Reading one before or during an assessment invalidates the test. They exist for the human or harness that scores the run, not for the agent being scored."
  ],
  "data_classification": "synthetic. No personal data, no real organisation, no real regulation. Citations are synthetic identifiers and must be preserved verbatim, never resolved against real law.",
